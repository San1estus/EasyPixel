<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="CrochetIt.Views.PatternEditorPage">

    <Grid Margin ="20" RowSpacing="20" RowDefinitions="Auto, Auto, *, Auto" ColumnDefinitions = "*, *">
        <!-- Selector de resolución -->

        <Picker x:Name="gridSizePicker" Title="Resolución del patrón" Grid.Row="0" Grid.ColumnSpan="2">
            <Picker.Items>
                <x:String>32</x:String>
                <x:String>64</x:String>
                <x:String>128</x:String>
                <x:String>256</x:String>
            </Picker.Items>
        </Picker>

        <!-- Botón para elegir imagen --> 
        <Button Text="Seleccionar imagen" Clicked="OnSelectImageClicked" Grid.Row="1"/>

        <!-- Canvas donde se dibuja el patrón -->
        <skia:SKCanvasView x:Name="patternCanvas"
                   Grid.Row="2"
                   PaintSurface="OnCanvasViewPaintSurface"/>
        
        <!-- Entry para el titulo del patrón -->
        <Entry x:Name="nombrePatron" Grid.Row="3" Grid.Column="0"></Entry>
        
        <!-- Botón para crear el patrón -->
        <Button x:Name="subirImagen" Text="Subir Patrón" Clicked="OnUploadImageClicked" Grid.Row="3" Grid.Column="1"></Button>
    </Grid>

</ContentPage>