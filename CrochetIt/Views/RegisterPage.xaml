<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CrochetIt.Views.RegisterPage"
             Title="RegisterPage">
    <VerticalStackLayout>
        <Image Source="logo.png" HeightRequest="100" WidthRequest="100"/>

        <Label Text="Correo electrónico" FontSize="24" FontAttributes="Bold" Margin="0, 10, 0, 10" />
        <Entry Text="{Binding Email}" Placeholder="Email" Keyboard="Email" Margin="0,10,0,10"/>

        <Label Text="Nombre de Usuario" FontSize="24" FontAttributes="Bold" Margin="0,10,0,10"/>
        <Entry Text="{Binding Username}" Placeholder="Usuario" />

        <Label Text="Contraseña" FontSize="24" FontAttributes="Bold" Margin="0,10,0,10"/>
        <Entry Text="{Binding Password}" Placeholder="Contraseña" IsPassword="True" Margin="0,10,0,10"/>

        <Button Text="Registrarse" Command="{Binding RegisterCommand}" Margin="0,10,0,10"/>
        <Button Text="¿Ya tienes cuenta? Inicia Sesión" Command="{Binding GoToLoginCommand}" Margin="0,10,0,10"/>

        <Label Text="{Binding ErrorMessage}" TextColor="Red" />
    </VerticalStackLayout>
</ContentPage>