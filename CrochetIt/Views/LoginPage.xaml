<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CrochetIt.Views.LoginPage"
             Title="LoginPage">
    <VerticalStackLayout>
        <Image Source="logo.png" HeightRequest="100" WidthRequest="100"/>
        <Label Text="Iniciar Sesión" FontSize="24" FontAttributes="Bold" Padding="20"/>

        <Entry Text="{Binding Email}" Placeholder="Email" Keyboard="Email" Margin="0, 10, 0, 10"/>
        <Entry Text="{Binding Password}" Placeholder="Contraseña" IsPassword="True" Margin="0, 10, 0, 10"/>

        <Button Text="Iniciar Sesión" Command="{Binding LoginCommand}" Margin="0, 10, 0, 10"/>
        <Button Text="¿No tienes cuenta? Regístrate" Command="{Binding GoToRegisterCommand}" Margin="0, 10, 0, 10"/>

        <Label Text="{Binding ErrorMessage}" TextColor="Red" />
    </VerticalStackLayout>
</ContentPage>