<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CrochetIt.Views.DetallePage"
             Title="DetallePage">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="5">
            <Label x:Name="lblNombre"
             FontSize="28"
             FontAttributes="Bold"
             HorizontalOptions="Center"
             Margin="0,0,0,20" />

            <Image x:Name="imgPatron"
             HeightRequest="200"
             Aspect="AspectFit" 
             Margin="0,0,0,20" />

            <Button Text="Descargar" Clicked="OnDescargarClicked"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>