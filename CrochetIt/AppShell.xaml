<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CrochetIt.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:CrochetIt"
    xmlns:views="clr-namespace:CrochetIt.Views"
    Title="CrochetIt">

    <TabBar>
        <ShellContent
            Title="Catálogo"
            Icon="navegar.png"
            ContentTemplate="{DataTemplate views:CatalogoPage}"
            Route="CatalogoPage" />
        <ShellContent
            Title="Crear Patrón"
            Icon="crear.png"
            ContentTemplate="{DataTemplate views:PatternEditorPage}"
            Route="PatternEditorPage" />
    </TabBar>
</Shell>
